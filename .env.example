# URL base del backend Express (carpeta BE). Debe terminar en /api.
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# RF-01.1 — Validación de correo institucional del estudiante.
# true  = PRODUCCIÓN: exige @ucr.ac.cr (cumple el documento). ← usar en el deploy del cliente
# false = DESARROLLO/DEMO: permite correos de prueba (el equipo no tiene acceso UCR).
NEXT_PUBLIC_STRICT_UCR_EMAIL=true
